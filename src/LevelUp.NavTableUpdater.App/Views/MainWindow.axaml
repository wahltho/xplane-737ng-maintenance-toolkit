<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:LevelUp.NavTableUpdater.App.ViewModels"
        xmlns:core="using:LevelUp.NavTableUpdater.Core"
        xmlns:analysis="using:LevelUp.NavTableUpdater.Core.Analysis"
        xmlns:aircraft="using:LevelUp.NavTableUpdater.Core.Aircraft"
        xmlns:upstream="using:LevelUp.NavTableUpdater.Core.Upstream"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1180" d:DesignHeight="780"
        x:Class="LevelUp.NavTableUpdater.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="X-Plane 737NG Maintenance Toolkit"
        Width="1180"
        Height="780"
        MinWidth="980"
        MinHeight="680">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Window.Styles>
        <Style Selector="Border.card">
            <Setter Property="Background" Value="#FFFFFFFF"/>
            <Setter Property="BorderBrush" Value="#D8DEE8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="14"/>
        </Style>
        <Style Selector="TextBlock.label">
            <Setter Property="Foreground" Value="#667085"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style Selector="TextBlock.value">
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style Selector="Button.primary">
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="Border.operation-card">
            <Setter Property="Background" Value="#160A3D"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="18"/>
        </Style>
        <Style Selector="Border.console-card">
            <Setter Property="Background" Value="#10072C"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="14"/>
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto,Auto,*" Background="#F3F6FA">
        <Border Grid.Row="0" Background="#111827" Padding="18,14">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Spacing="2">
                    <TextBlock Text="X-Plane 737NG Maintenance Toolkit" Foreground="White" FontSize="20" FontWeight="SemiBold"/>
                    <TextBlock Text="VNAV tables and 737NG view maintenance" Foreground="#CBD5E1"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <TextBlock Text="App update: VeloPack" Foreground="#D1FAE5" VerticalAlignment="Center"/>
                    <TextBlock Text="Content: manifest-driven" Foreground="#DBEAFE" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Background="#FFF7ED"
                BorderBrush="#FDBA74"
                BorderThickness="0,0,0,1"
                Padding="14,10"
                IsVisible="{Binding RestartNoticeVisible}">
            <TextBlock Text="{Binding RestartNotice}" Foreground="#9A3412" FontWeight="SemiBold"/>
        </Border>

        <Grid Grid.Row="2" ColumnDefinitions="320,*" Margin="16" ColumnSpacing="16">
            <Border Classes="card">
                <Grid RowDefinitions="Auto,Auto,Auto,*" RowSpacing="14">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Aircraft Target" FontSize="18" FontWeight="SemiBold"/>
                        <TextBlock Text="Detection is structural. Folder names are not trusted." Foreground="#667085" TextWrapping="Wrap"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Spacing="8">
                        <TextBlock Classes="label" Text="Selected folder"/>
                        <TextBox Text="{Binding SelectedAircraftPath}" PlaceholderText="/path/to/Zibo or LevelUp aircraft folder"/>
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                            <Button Grid.Column="0" Content="Auto-detect" Command="{Binding AutoDetectCommand}" HorizontalAlignment="Stretch"/>
                            <Button Grid.Column="1" Content="Browse" Click="BrowseAircraft_Click" HorizontalAlignment="Stretch"/>
                        </Grid>
                        <Button Content="Scan selected folder" Command="{Binding ScanCommand}" Classes="primary" HorizontalAlignment="Stretch"/>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Spacing="4">
                        <TextBlock Classes="label" Text="Detected candidates"/>
                        <ListBox ItemsSource="{Binding DetectedTargets}"
                                 SelectedItem="{Binding SelectedCandidate}"
                                 MinHeight="120"
                                 MaxHeight="180">
                            <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="core:AircraftCandidate">
                                    <StackPanel Spacing="2" Margin="0,4">
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding Path}" Foreground="#667085" FontSize="11" TextWrapping="Wrap"/>
                                        <TextBlock Text="{Binding Reason}" Foreground="#475467" FontSize="11"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>

                    <StackPanel Grid.Row="3" Spacing="6">
                        <TextBlock Classes="label" Text="Package source"/>
                        <TextBlock Text="{Binding PackageId}" FontWeight="SemiBold" TextWrapping="Wrap"/>
                        <TextBlock Text="{Binding PackageSource}" Foreground="#667085"/>
                        <TextBlock Text="{Binding RepositoryUrl}" Foreground="#2563EB" TextWrapping="Wrap"/>
                    </StackPanel>
                </Grid>
            </Border>

            <ScrollViewer Grid.Column="1">
                <StackPanel Spacing="16">
                    <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="12">
                        <Border Classes="card">
                            <StackPanel Spacing="4">
                                <TextBlock Classes="label" Text="Aircraft status"/>
                                <TextBlock Classes="value" Text="{Binding AircraftStatus}" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="1" Classes="card">
                            <StackPanel Spacing="4">
                                <TextBlock Classes="label" Text="Installed package"/>
                                <TextBlock Classes="value" Text="{Binding LocalPackageVersion}"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="2" Classes="card">
                            <StackPanel Spacing="4">
                                <TextBlock Classes="label" Text="Available package"/>
                                <TextBlock Classes="value" Text="{Binding AvailablePackageVersion}"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="3" Classes="card">
                            <StackPanel Spacing="4">
                                <TextBlock Classes="label" Text="Line endings"/>
                                <TextBlock Classes="value" Text="{Binding LineEnding}"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Border Classes="card">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Scan Summary" FontSize="16" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding StatusSummary}" TextWrapping="Wrap"/>
                            <TextBlock Classes="label" Text="Target script"/>
                            <TextBlock Text="{Binding TargetScriptPath}" FontFamily="Menlo,Consolas,monospace" FontSize="12" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <Border Classes="card">
                        <StackPanel Spacing="10">
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="View Utilities" FontSize="16" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding ViewUtilitySummary}" TextWrapping="Wrap"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="4" MinWidth="170">
                                    <TextBlock Classes="label" Text="X-Plane process"/>
                                    <TextBlock Text="{Binding XPlaneProcessStatus}" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Grid>

                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                <StackPanel Spacing="4">
                                    <TextBlock Classes="label" Text="View status"/>
                                    <TextBlock Text="{Binding ViewUtilityStatus}" FontSize="16" FontWeight="SemiBold"/>
                                </StackPanel>
                                <WrapPanel Grid.Column="1" ItemSpacing="8" LineSpacing="8" HorizontalAlignment="Right">
                                    <Button Content="Adapt Quick Views"
                                            Command="{Binding AdaptQuickViewsForCgCommand}"
                                            IsEnabled="{Binding ActionsEnabled}"/>
                                    <Button Content="Apply QV0 to Default View"
                                            Command="{Binding ApplyQv0ToDefaultViewCommand}"
                                            IsEnabled="{Binding ActionsEnabled}"/>
                                    <Button Content="Restore Latest Backup"
                                            Command="{Binding RestoreLatestBackupCommand}"
                                            IsEnabled="{Binding ActionsEnabled}"/>
                                </WrapPanel>
                            </Grid>

                            <ListBox ItemsSource="{Binding ViewVariants}"
                                     SelectedItem="{Binding SelectedViewVariant}"
                                     MaxHeight="430">
                                <ListBox.ItemTemplate>
                                    <DataTemplate x:DataType="aircraft:AircraftVariantViewAnalysis">
                                        <Border BorderBrush="#E5E7EB"
                                                BorderThickness="1"
                                                CornerRadius="6"
                                                Padding="10"
                                                Margin="0,4">
                                            <StackPanel Spacing="7">
                                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                                    <StackPanel Spacing="2">
                                                        <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold"/>
                                                        <TextBlock Text="{Binding SourceRef}" Foreground="#667085" FontSize="12"/>
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="1" Text="{Binding Status}" FontWeight="SemiBold"/>
                                                </Grid>
                                                <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                                                    <StackPanel Spacing="2">
                                                        <TextBlock Classes="label" Text="Current CG"/>
                                                        <TextBlock Text="{Binding CurrentCgDisplay}" FontFamily="Menlo,Consolas,monospace" FontSize="12" TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="1" Spacing="2">
                                                        <TextBlock Classes="label" Text="Reference CG"/>
                                                        <TextBlock Text="{Binding ReferenceCgDisplay}" FontFamily="Menlo,Consolas,monospace" FontSize="12" TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                </Grid>
                                                <StackPanel Spacing="2">
                                                    <TextBlock Classes="label" Text="Detected delta"/>
                                                    <TextBlock Text="{Binding DeltaDisplay}" FontFamily="Menlo,Consolas,monospace" FontSize="12" TextWrapping="Wrap"/>
                                                </StackPanel>
                                                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="10">
                                                    <TextBlock Text="{Binding IdentityStatus}" Foreground="#667085" TextWrapping="Wrap"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding QuickViewStatus}" Foreground="#667085" TextWrapping="Wrap"/>
                                                    <TextBlock Grid.Column="2" Text="{Binding DefaultViewStatus}" Foreground="#667085" TextWrapping="Wrap"/>
                                                </Grid>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <ItemsControl ItemsSource="{Binding ViewFindings}"/>
                        </StackPanel>
                    </Border>

                    <Border Classes="card">
                        <StackPanel Spacing="10">
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Zibo Upstream Packages" FontSize="16" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding UpstreamUpdateSummary}" TextWrapping="Wrap"/>
                                </StackPanel>
                                <WrapPanel Grid.Column="1" ItemSpacing="8" LineSpacing="8" VerticalAlignment="Top">
                                    <Button Content="Refresh"
                                            Command="{Binding RefreshZiboUpdateCheckCommand}"
                                            IsEnabled="{Binding ActionsEnabled}"/>
                                    <Button Content="Import ZIP"
                                            Click="ImportAircraftUpdateZip_Click"
                                            IsEnabled="{Binding ActionsEnabled}"/>
                                    <Button Content="Dry-run ZIPs"
                                            Command="{Binding DryRunAircraftUpdateCommand}"
                                            IsEnabled="{Binding ActionsEnabled}"/>
                                </WrapPanel>
                            </Grid>

                            <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="12">
                                <StackPanel Spacing="2">
                                    <TextBlock Classes="label" Text="Status"/>
                                    <TextBlock Text="{Binding UpstreamUpdateStatus}" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="2">
                                    <TextBlock Classes="label" Text="Installed"/>
                                    <TextBlock Text="{Binding UpstreamLocalVersion}" FontFamily="Menlo,Consolas,monospace"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" Spacing="2">
                                    <TextBlock Classes="label" Text="Available"/>
                                    <TextBlock Text="{Binding UpstreamAvailableVersion}" FontFamily="Menlo,Consolas,monospace"/>
                                </StackPanel>
                                <StackPanel Grid.Column="3" Spacing="2">
                                    <TextBlock Classes="label" Text="Plan"/>
                                    <TextBlock Text="{Binding UpstreamPlanAction}" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Grid>

                            <StackPanel Spacing="4">
                                <TextBlock Classes="label" Text="Source"/>
                                <TextBlock Text="{Binding UpstreamSource}" Foreground="#2563EB" TextWrapping="Wrap"/>
                                <TextBlock Text="{Binding UpstreamLastChecked}" Foreground="#667085" FontSize="12"/>
                                <TextBlock Classes="label" Text="Cache"/>
                                <TextBlock Text="{Binding UpstreamCacheRoot}" Foreground="#667085" TextWrapping="Wrap"/>
                            </StackPanel>

                            <StackPanel Spacing="6">
                                <TextBlock Classes="label" Text="Required packages"/>
                                <ItemsControl ItemsSource="{Binding UpstreamRequiredPackages}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="upstream:AircraftUpdatePackage">
                                            <Grid ColumnDefinitions="150,90,*,*" ColumnSpacing="10" Margin="0,3">
                                                <TextBlock Text="{Binding Kind}" FontWeight="SemiBold"/>
                                                <TextBlock Grid.Column="1" Text="{Binding Version}" FontFamily="Menlo,Consolas,monospace"/>
                                                <TextBlock Grid.Column="2" Text="{Binding FileName}" TextWrapping="Wrap"/>
                                                <TextBlock Grid.Column="3" Text="{Binding SourceUrl}" Foreground="#667085" TextWrapping="Wrap"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>

                            <StackPanel Spacing="6">
                                <TextBlock Classes="label" Text="Cache status"/>
                                <ItemsControl ItemsSource="{Binding UpstreamPackageCacheEntries}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="upstream:AircraftUpdatePackageCacheEntry">
                                            <Grid ColumnDefinitions="140,*,90,90,*" ColumnSpacing="10" Margin="0,3">
                                                <TextBlock Text="{Binding State}" FontWeight="SemiBold"/>
                                                <TextBlock Grid.Column="1" Text="{Binding Package.FileName}" TextWrapping="Wrap"/>
                                                <TextBlock Grid.Column="2" Text="{Binding Package.Version}" FontFamily="Menlo,Consolas,monospace"/>
                                                <TextBlock Grid.Column="3" Text="{Binding SizeBytes}" FontFamily="Menlo,Consolas,monospace"/>
                                                <TextBlock Grid.Column="4" Text="{Binding Sha256}" Foreground="#667085" TextWrapping="Wrap"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>

                            <StackPanel Spacing="6">
                                <TextBlock Classes="label" Text="Aircraft update dry-run"/>
                                <TextBlock Text="{Binding UpstreamDryRunSummary}" TextWrapping="Wrap"/>
                                <ItemsControl ItemsSource="{Binding UpstreamDryRunEntries}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="upstream:AircraftUpdateDryRunEntry">
                                            <Grid ColumnDefinitions="150,*,90,*" ColumnSpacing="10" Margin="0,3">
                                                <TextBlock Text="{Binding Action}" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                                <TextBlock Grid.Column="1" Text="{Binding RelativePath}" TextWrapping="Wrap"/>
                                                <TextBlock Grid.Column="2" Text="{Binding SizeBytes}" FontFamily="Menlo,Consolas,monospace"/>
                                                <TextBlock Grid.Column="3" Text="{Binding Detail}" Foreground="#667085" TextWrapping="Wrap"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>

                            <ItemsControl ItemsSource="{Binding UpstreamFindings}"/>
                        </StackPanel>
                    </Border>

                    <Border Classes="operation-card" IsVisible="{Binding OperationPanelVisible}">
                        <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="16">
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="{Binding OperationTitle}"
                                               Foreground="#F8FAFC"
                                               FontSize="24"
                                               FontWeight="SemiBold"
                                               TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding OperationSubtitle}"
                                               Foreground="#C4B5FD"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Top">
                                    <TextBlock Text="Elapsed" Foreground="#C4B5FD" FontSize="18" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding OperationElapsed}" Foreground="#F8FAFC" FontSize="18" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Grid>

                            <Grid Grid.Row="1" RowDefinitions="Auto,Auto" RowSpacing="8">
                                <ProgressBar Minimum="0"
                                             Maximum="100"
                                             Value="{Binding OperationProgress}"
                                             Height="14"
                                             Background="#2E1065"
                                             Foreground="#BDEB73"
                                             CornerRadius="6"/>
                                <Grid Grid.Row="1" ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                    <TextBlock Text="{Binding OperationProgressText}"
                                               Foreground="#DDD6FE"
                                               FontFamily="Menlo,Consolas,monospace"
                                               FontSize="12"
                                               TextWrapping="Wrap"/>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding OperationStatus}"
                                               Foreground="#BDEB73"
                                               FontWeight="SemiBold"/>
                                </Grid>
                            </Grid>

                            <Border Grid.Row="2" Classes="console-card">
                                <Grid RowDefinitions="Auto,*" RowSpacing="10">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <TextBlock Text="Console" Foreground="#F8FAFC" FontWeight="SemiBold"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding OperationStatus}"
                                                   Foreground="#BDEB73"
                                                   FontFamily="Menlo,Consolas,monospace"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"/>
                                    </Grid>
                                    <TextBox Grid.Row="1"
                                             Text="{Binding OperationLog}"
                                             IsReadOnly="True"
                                             AcceptsReturn="True"
                                             TextWrapping="Wrap"
                                             FontFamily="Menlo,Consolas,monospace"
                                             Foreground="#E9D5FF"
                                             Background="#10072C"
                                             BorderThickness="0"
                                             MinHeight="96"/>
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>

                    <Border Classes="card">
                        <StackPanel Spacing="10">
                            <TextBlock Text="Components" FontSize="16" FontWeight="SemiBold"/>
                            <ItemsControl ItemsSource="{Binding Components}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="analysis:ComponentStatus">
                                        <Grid ColumnDefinitions="220,100,90,*" ColumnSpacing="10" Margin="0,4">
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                            <TextBlock Grid.Column="1" Text="{Binding State}"/>
                                            <TextBlock Grid.Column="2" Text="{Binding Version}"/>
                                            <TextBlock Grid.Column="3" Text="{Binding Detail}" Foreground="#667085" TextWrapping="Wrap"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="16">
                        <Border Classes="card">
                            <StackPanel Spacing="10">
                                <TextBlock Text="Planned Changes" FontSize="16" FontWeight="SemiBold"/>
                                <ItemsControl ItemsSource="{Binding PlannedChanges}"/>
                                <TextBlock Text="Package actions below modify manifest-owned VNAV content only after validation and backup. Dry-run reviews planned changes without writing files." Foreground="#B45309" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                <WrapPanel ItemSpacing="8" LineSpacing="8">
                                    <Button Content="Dry-run" Command="{Binding DryRunCommand}" IsEnabled="{Binding ActionsEnabled}"/>
                                    <Button Content="Install" Command="{Binding RunPackageActionCommand}" CommandParameter="Install" IsEnabled="{Binding ActionsEnabled}"/>
                                    <Button Content="Update" Command="{Binding RunPackageActionCommand}" CommandParameter="Update" IsEnabled="{Binding ActionsEnabled}"/>
                                    <Button Content="Repair" Command="{Binding RunPackageActionCommand}" CommandParameter="Repair" IsEnabled="{Binding ActionsEnabled}"/>
                                    <Button Content="Restore" Command="{Binding RunPackageActionCommand}" CommandParameter="Restore" IsEnabled="{Binding ActionsEnabled}"/>
                                    <Button Content="Uninstall" Command="{Binding RunPackageActionCommand}" CommandParameter="Uninstall" IsEnabled="{Binding ActionsEnabled}"/>
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1" Classes="card">
                            <StackPanel Spacing="10">
                                <TextBlock Text="Findings" FontSize="16" FontWeight="SemiBold"/>
                                <ItemsControl ItemsSource="{Binding Findings}"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Border Classes="card">
                        <Grid RowDefinitions="Auto,*" RowSpacing="8">
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Text="Install Log" FontSize="16" FontWeight="SemiBold"/>
                                <Button Grid.Column="1" Content="Clear" Command="{Binding ClearLogCommand}"/>
                            </Grid>
                            <TextBox Grid.Row="1"
                                     Text="{Binding InstallLog}"
                                     IsReadOnly="True"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     FontFamily="Menlo,Consolas,monospace"
                                     MinHeight="160"/>
                        </Grid>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>

</Window>
