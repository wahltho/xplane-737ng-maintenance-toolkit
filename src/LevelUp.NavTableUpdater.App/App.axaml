<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="LevelUp.NavTableUpdater.App.App"
             xmlns:local="using:LevelUp.NavTableUpdater.App"
             RequestedThemeVariant="Light">
             <!-- The current UI is explicitly light-themed so Linux AppImage builds stay readable under dark desktop themes. -->

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>

    <Application.Styles>
        <FluentTheme />
    </Application.Styles>
</Application>
